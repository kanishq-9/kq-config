{
  "name": "kq-config",
  "version": "1.0.0",
  "description": "Professional .kq config file parser with server/client block separation, environment variable injection, layered overrides, and schema validation.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node test/index.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "config",
    "kq",
    "configuration",
    "env",
    "parser",
    "server",
    "client",
    "dotenv",
    "settings"
  ],
  "author": "Kanishq.R.Purohit <kanishq.r.purohit@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kanishq-9/kq-config.git"
  },
  "bugs": {
    "url": "https://github.com/kanishq-9/kq-config/issues"
  },
  "homepage": "https://github.com/kanishq-9/kq-config#readme",
  "engines": {
    "node": ">=14.0.0"
  }
}
