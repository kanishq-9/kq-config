{
  "name": "kq-config",
  "version": "1.0.3",
  "description": "Professional .kq config parser — server/client block separation, built-in .env support, layered overrides, schema validation. Zero dependencies.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build":          "node scripts/build.js",
    "test":           "node test/index.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "config",
    "kq",
    "konfig-query",
    "configuration",
    "env",
    "dotenv",
    "parser",
    "server",
    "client",
    "settings",
    "environment",
    "secure"
  ],
  "author": "kanishq.R.Purohit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kanishq-9/kq-config.git"
  },
  "bugs": {
    "url": "https://github.com/kanishq-9/kq-config/issues"
  },
  "homepage": "https://github.com/kanishq-9/kq-config#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}